# Phase 3 LLM Integration - Environment Variables
# Gemini + Chroma Cloud + Daily Corpus Refresh (9 AM IST)

# CHROMA CLOUD (required)
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=ck-8Ku1UYPuwbyn6rZYvjxaw1r2Weq8uQQbhENhgPPDUQyJ
CHROMA_TENANT=294acee2-3774-495c-939a-15b101ff9a19
CHROMA_DATABASE=Demo

# LLM provider settings (gemini only)
LLM_PROVIDER=gemini

# Gemini / Google Generative API (required)
GEMINI_API_KEY=AIzaSyB1gJR6tD-PF5cShiEQr8Dt8jaqlVmNxV8
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.1

# Hybrid Search Tuning
RRF_K_PARAMETER=60
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=5
GROUPBY_LIMIT=3

# Chunking Parameters
CHUNK_SIZE_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# Query Parameters
MIN_SIMILARITY_SCORE=0.85
QUERY_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Data Import
IMPORT_BATCH_SIZE=100
PRESERVE_METADATA=true

# Redis (optional caching)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
USE_RESULT_CACHE=false
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=5

# Redis (optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/phase_3.log
