# Phase 3 LLM Integration - Environment Variables Template
# Gemini + Chroma Cloud + 15 Groww AMC URLs + Daily 9 AM IST Refresh

# ============================================================================
# CHROMA CLOUD Configuration (Required)
# ============================================================================

# Get these from https://www.trychroma.com/dashboard
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your-chroma-api-key-here
CHROMA_TENANT=your-chroma-tenant-id-here
CHROMA_DATABASE=Demo

# ============================================================================
# GEMINI LLM Configuration (Required - Google Generative AI)
# ============================================================================

# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=text-bison-001
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.1  # Low temp for factual accuracy (no advice)

# ============================================================================
# Hybrid Search Configuration (Tuning)
# ============================================================================

# RRF (Reciprocal Rank Fusion) parameters
RRF_K_PARAMETER=60
DENSE_WEIGHT=0.6          # 60% weight to dense (semantic) search
SPARSE_WEIGHT=0.4         # 40% weight to sparse (keyword) search

# Result retrieval
TOP_K_DENSE=20            # Get top 20 from dense search
TOP_K_SPARSE=20           # Get top 20 from sparse search
TOP_K_FINAL=5             # Return top 5 after fusion & dedup

# ============================================================================
# GroupBy Configuration (Deduplication)
# ============================================================================

GROUPBY_FIELD=source_url
GROUPBY_LIMIT=3           # Max 3 chunks per source

# ============================================================================
# Chunking Configuration
# ============================================================================

CHUNK_SIZE_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# ============================================================================
# Query Configuration
# ============================================================================

MIN_SIMILARITY_SCORE=0.85
QUERY_TIMEOUT_SECONDS=30

# ============================================================================
# Logging
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/phase_3.log

# ============================================================================
# Caching (Optional)
# ============================================================================

REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
USE_RESULT_CACHE=false

# ============================================================================
# Data Import Configuration
# ============================================================================

IMPORT_BATCH_SIZE=100
PRESERVE_METADATA=true
